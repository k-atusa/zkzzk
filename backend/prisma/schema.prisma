generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model user {
  id             String      @id @default(uuid())
  username       String      @unique
  password_hash  String
  is_admin       Boolean?
  created_at     DateTime?   @default(now())
  totp_secret    String?
  totp_enabled   Boolean?
  nid_aut        String?
  nid_ses        String?
  discord_webhook_url   String?
  youtube_client_id     String?
  youtube_client_secret String?
  youtube_refresh_token String?
  youtube_auto_upload   Boolean?    @default(true)
  delete_after_upload   Boolean?    @default(false)
  live_resolution       String?     @default("1080p")
  vod_resolution        String?     @default("1080p")
  recordings     recording[]
  streamers      streamer[]  @relation("StreamerUser")
  cookie_streamers streamer[] @relation("StreamerCookieUser")

  @@map("account")
}

model settings {
  id                  String   @id @default(uuid())
  initialized           Boolean?

  @@map("settings")
}

model streamer {
  id                      String      @id @default(uuid())
  channel_url             String
  nickname                String?
  user_id                 String?
  cookie_user_id          String?
  is_active               Boolean?
  created_at              DateTime?   @default(now())
  last_checked            DateTime?
  last_live               DateTime?
  is_recording            Boolean?
  is_paused               Boolean?    @default(false)
  current_broadcast_title String?
  current_broadcast_category String?
  current_broadcast_tags     String?
  process_id              Int?
  recordings              recording[]
  cookie_user             user?       @relation("StreamerCookieUser", fields: [cookie_user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  user                    user?       @relation("StreamerUser", fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([user_id, channel_url])
  @@map("streamers")
}

model recording {
  id               String    @id @default(uuid())
  streamer_id      String?
  user_id          String?
  filename         String
  title            String?
  resolution       String?
  created_at       DateTime? @default(now())
  youtube_status   String?
  youtube_video_id String?
  is_recording     Boolean?  @default(false)
  streamer         streamer? @relation(fields: [streamer_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  user             user?     @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@map("recording")
}
